APP_NAME="Text To Speech"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app-name.onrender.com

# LibreOffice path (not used in production/Render - leave blank)
LIBREOFFICE_PATH=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------
# Aiven MySQL Database (get values from Aiven Console)
# Service > Connection Information > Quick Connect
# ---------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=your-service.aivencloud.com
DB_PORT=19174
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=your-aiven-db-password

# Aiven SSL Certificate (required for Aiven MySQL)
# Option A (Recommended): Paste the base64-encoded contents of the Aiven CA cert
#   Run: base64 -w 0 ca.pem  (Linux/Mac)  OR  certutil -encode ca.pem ca_b64.txt  (Windows)
#   Then paste the single-line base64 string below
DB_SSL_CA_BASE64=

# Option B: Path to ca.pem file (if mounting via volume or placing manually)
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/aiven-ca.pem

# ---------------------------------------------------------
# Admin Seeder Credentials (used by database/seeders)
# ---------------------------------------------------------
LMS_ADMIN_EMAIL=admin@yourdomain.com
LMS_ADMIN_PASSWORD=change-this-strong-password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# VoiceRSS Text-to-Speech API
# Get free key at: https://www.voicerss.org/registration.aspx
VOICERSS_API_KEY=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
